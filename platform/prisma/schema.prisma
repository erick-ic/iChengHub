generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ToolCard {
  id        String   @id @default(cuid())
  name      String
  nameEn    String?
  desc      String
  descEn    String?
  url       String
  logoUrl   String
  category  String
  status    Int      @default(0)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}