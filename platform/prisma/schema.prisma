generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ToolCard {
  id         String   @id @default(cuid())
  name       String
  nameEn     String?
  desc       String
  descEn     String?
  url        String?
  logoUrl    String
  category   String
  categoryEn String?
  status     Int      @default(0)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now()) @db.Timestamptz(0)
  updatedAt  DateTime @updatedAt @db.Timestamptz(0)
}

model NavLink {
  id         String   @id @default(cuid())
  name       String
  nameEn     String?
  desc       String
  descEn     String?
  url        String
  iconUrl    String?
  category   String
  categoryEn String?
  status     Int      @default(1)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now()) @db.Timestamptz(0)
  updatedAt  DateTime @updatedAt @db.Timestamptz(0)
}

model Prompt {
  id         String   @id @default(cuid())
  title      String
  titleEn    String?
  category   String
  categoryEn String?
  toolId     String
  imageUrl   String
  promptText String
  views      Int      @default(0)
  likes      Int      @default(0)
  comments   Int      @default(0)
  status     Int      @default(0)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now()) @db.Timestamptz(0)
  updatedAt  DateTime @updatedAt @db.Timestamptz(0)
}

model ToolSubmission {
  id          String   @id @default(cuid())
  name        String
  url         String
  description String
  contact     String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now()) @db.Timestamptz(0)
  updatedAt   DateTime @updatedAt @db.Timestamptz(0)
}

model ToolDemand {
  id           String   @id @default(cuid())
  title        String
  detail       String
  referenceUrl String?
  contact      String?
  status       String   @default("PENDING")
  createdAt    DateTime @default(now()) @db.Timestamptz(0)
  updatedAt    DateTime @updatedAt @db.Timestamptz(0)
}