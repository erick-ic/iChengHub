generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ToolCard {
  id        String   @id @default(cuid())
  name      String
  nameEn    String?
  desc      String
  descEn    String?
  url       String
  logoUrl   String
  category  String
  createdAt DateTime @default(now())
}